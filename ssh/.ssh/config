# ~/.ssh/config  —  stowed from ~/dotfiles/ssh/.ssh/config
#
# NON-SECRET ONLY. Keys never live in this repo. Anything machine-specific or
# sensitive (private host aliases, jump hosts, IdentityFile overrides) goes in
# ~/.ssh/config.local, which is git-ignored and Included first below so its
# settings win (ssh uses the FIRST matching value for each option).
Include ~/.ssh/config.local

# ---- Defaults for every host ------------------------------------------------
Host *
    # Load keys into the agent on first use and keep the passphrase in the macOS
    # Keychain, so you only unlock once per login.
    AddKeysToAgent yes
    UseKeychain yes
    IdentityFile ~/.ssh/id_ed25519
    # Reuse a single connection for multiple sessions to the same host (faster).
    ControlMaster auto
    ControlPath ~/.ssh/control/%C
    ControlPersist 10m
    # Keep idle connections alive through NAT/firewalls.
    ServerAliveInterval 60
    ServerAliveCountMax 3

