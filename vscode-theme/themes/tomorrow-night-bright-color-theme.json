{
  "$schema": "vscode://schemas/color-theme",
  "name": "Tomorrow Night Bright",
  "type": "dark",
  "semanticHighlighting": true,
  "colors": {
    "foreground": "#EAEAEA",
    "focusBorder": "#7AA6DA",
    "selection.background": "#424242C0",

    "editor.background": "#000000",
    "editor.foreground": "#EAEAEA",
    "editorLineNumber.foreground": "#515151",
    "editorLineNumber.activeForeground": "#EAEAEA",
    "editor.lineHighlightBackground": "#2A2A2A80",
    "editor.selectionBackground": "#424242C0",
    "editor.selectionHighlightBackground": "#42424260",
    "editor.findMatchBackground": "#E7C54766",
    "editor.findMatchHighlightBackground": "#E7C54733",
    "editor.wordHighlightBackground": "#7AA6DA33",
    "editorCursor.foreground": "#EAEAEA",
    "editorWhitespace.foreground": "#2A2A2A",
    "editorIndentGuide.background1": "#1A1A1A",
    "editorIndentGuide.activeBackground1": "#2A2A2A",
    "editorWidget.background": "#0D0D0D",
    "editorSuggestWidget.background": "#0D0D0D",
    "editorSuggestWidget.selectedBackground": "#1A1A1A",
    "editorHoverWidget.background": "#0D0D0D",
    "editorGroupHeader.tabsBackground": "#0A0A0A",

    "activityBar.background": "#0A0A0A",
    "activityBar.foreground": "#EAEAEA",
    "activityBar.inactiveForeground": "#969896",
    "activityBarBadge.background": "#7AA6DA",
    "activityBarBadge.foreground": "#000000",

    "sideBar.background": "#0A0A0A",
    "sideBar.foreground": "#EAEAEA",
    "sideBarSectionHeader.background": "#0D0D0D",
    "sideBarTitle.foreground": "#B4B7B4",

    "list.activeSelectionBackground": "#1A1A1A",
    "list.activeSelectionForeground": "#EAEAEA",
    "list.inactiveSelectionBackground": "#141414",
    "list.hoverBackground": "#1A1A1A",

    "statusBar.background": "#0D0D0D",
    "statusBar.foreground": "#B4B7B4",
    "statusBar.noFolderBackground": "#0D0D0D",
    "statusBar.debuggingBackground": "#E78C45",
    "statusBar.debuggingForeground": "#000000",

    "titleBar.activeBackground": "#0D0D0D",
    "titleBar.activeForeground": "#EAEAEA",
    "titleBar.inactiveBackground": "#0A0A0A",
    "titleBar.inactiveForeground": "#969896",

    "tab.activeBackground": "#000000",
    "tab.inactiveBackground": "#0A0A0A",
    "tab.activeForeground": "#EAEAEA",
    "tab.inactiveForeground": "#969896",
    "tab.activeBorderTop": "#7AA6DA",
    "tab.border": "#0D0D0D",

    "panel.background": "#000000",
    "panel.border": "#1A1A1A",
    "panelTitle.activeForeground": "#EAEAEA",

    "input.background": "#141414",
    "input.border": "#2A2A2A",
    "dropdown.background": "#141414",
    "button.background": "#7AA6DA",
    "button.foreground": "#000000",
    "badge.background": "#7AA6DA",
    "badge.foreground": "#000000",
    "progressBar.background": "#7AA6DA",

    "gitDecoration.modifiedResourceForeground": "#E7C547",
    "gitDecoration.deletedResourceForeground": "#D54E53",
    "gitDecoration.untrackedResourceForeground": "#B9CA4A",
    "errorForeground": "#D54E53",

    "terminal.background": "#000000",
    "terminal.foreground": "#EAEAEA",
    "terminal.ansiBlack": "#000000",
    "terminal.ansiRed": "#D54E53",
    "terminal.ansiGreen": "#B9CA4A",
    "terminal.ansiYellow": "#E7C547",
    "terminal.ansiBlue": "#7AA6DA",
    "terminal.ansiMagenta": "#C397D8",
    "terminal.ansiCyan": "#70C0B1",
    "terminal.ansiWhite": "#EAEAEA",
    "terminal.ansiBrightBlack": "#969896",
    "terminal.ansiBrightRed": "#D54E53",
    "terminal.ansiBrightGreen": "#B9CA4A",
    "terminal.ansiBrightYellow": "#E7C547",
    "terminal.ansiBrightBlue": "#7AA6DA",
    "terminal.ansiBrightMagenta": "#C397D8",
    "terminal.ansiBrightCyan": "#70C0B1",
    "terminal.ansiBrightWhite": "#FFFFFF"
  },
  "tokenColors": [
    { "scope": ["comment", "punctuation.definition.comment"], "settings": { "foreground": "#969896", "fontStyle": "italic" } },
    { "scope": ["string", "string.quoted", "string.template", "constant.other.symbol"], "settings": { "foreground": "#B9CA4A" } },
    { "scope": ["constant.numeric", "constant.character", "constant.other"], "settings": { "foreground": "#E78C45" } },
    { "scope": ["constant.language", "constant.language.boolean", "support.constant"], "settings": { "foreground": "#E78C45" } },
    { "scope": ["keyword", "keyword.control", "storage", "storage.type", "storage.modifier", "keyword.operator.new", "keyword.operator.expression"], "settings": { "foreground": "#C397D8" } },
    { "scope": ["keyword.operator"], "settings": { "foreground": "#EAEAEA" } },
    { "scope": ["entity.name.function", "support.function", "meta.function-call.generic", "variable.function"], "settings": { "foreground": "#70C0B1" } },
    { "scope": ["entity.name.type", "entity.name.class", "support.type", "support.class", "entity.other.inherited-class", "storage.type.class"], "settings": { "foreground": "#E78C45" } },
    { "scope": ["entity.name.tag", "punctuation.definition.tag"], "settings": { "foreground": "#7AA6DA" } },
    { "scope": ["entity.other.attribute-name"], "settings": { "foreground": "#E78C45" } },
    { "scope": ["variable", "variable.other", "variable.parameter", "meta.definition.variable.name"], "settings": { "foreground": "#EAEAEA" } },
    { "scope": ["variable.language", "variable.language.this"], "settings": { "foreground": "#7AA6DA" } },
    { "scope": ["support.variable", "support.constant.property-value"], "settings": { "foreground": "#70C0B1" } },
    { "scope": ["punctuation", "meta.brace", "punctuation.separator", "punctuation.terminator"], "settings": { "foreground": "#B4B7B4" } },
    { "scope": ["markup.heading", "entity.name.section"], "settings": { "foreground": "#C397D8", "fontStyle": "bold" } },
    { "scope": ["markup.bold"], "settings": { "foreground": "#E78C45", "fontStyle": "bold" } },
    { "scope": ["markup.italic"], "settings": { "foreground": "#7AA6DA", "fontStyle": "italic" } },
    { "scope": ["markup.inserted"], "settings": { "foreground": "#B9CA4A" } },
    { "scope": ["markup.deleted"], "settings": { "foreground": "#D54E53" } },
    { "scope": ["markup.changed"], "settings": { "foreground": "#E7C547" } },
    { "scope": ["markup.underline.link", "string.other.link"], "settings": { "foreground": "#70C0B1" } },
    { "scope": ["invalid", "invalid.illegal"], "settings": { "foreground": "#D54E53" } }
  ]
}
