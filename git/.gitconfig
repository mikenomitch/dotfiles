; ~/.gitconfig  —  stowed from ~/dotfiles/git/.gitconfig
; Inspired by github.com/elithrar/dotfiles. Apple Silicon paths (/opt/homebrew).

[user]
	name = Mike Nomitch
	email = mikenomitch@gmail.com
	; SSH-key commit signing (see [commit]/[tag] below). One-time setup on a new
	; machine: generate the key and list yourself as an allowed signer —
	;   ssh-keygen -t ed25519
	;   echo "mikenomitch@gmail.com $(cat ~/.ssh/id_ed25519.pub)" >> ~/.ssh/allowed_signers
	; Until that's done, either run the two lines above or comment out gpgsign.
	signingkey = ~/.ssh/id_ed25519.pub

[gpg]
	format = ssh
[gpg "ssh"]
	allowedSignersFile = ~/.ssh/allowed_signers

[commit]
	gpgsign = true
[tag]
	gpgsign = true

[core]
	editor = zed --wait
	excludesfile = ~/.gitignore
	fileMode = false
	pager = delta

[interactive]
	diffFilter = delta --color-only

[delta]
	navigate = true   ; use n / N to move between diff sections

[push]
	default = simple
	autoSetupRemote = true
[fetch]
	prune = true
[pull]
	rebase = true

[merge]
	conflictStyle = zdiff3
[diff]
	algorithm = histogram
	colorMoved = default

[rerere]
	enabled = true
[rebase]
	autosquash = true

[branch]
	sort = -committerdate
[column]
	ui = auto
[log]
	decorate = true

[init]
	defaultBranch = main

[credential]
	helper = osxkeychain

[alias]
	pf = push --force-with-lease
	pr = "!f() { git fetch origin pull/$1/head:$2; }; f"
	rebase-main = "!f() { git fetch origin main && git rebase origin/main; }; f"
