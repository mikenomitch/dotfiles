{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",

  "//": "User-scope settings — apply to every project. Project repos can add a",
  "//2": ".claude/settings.json that MERGES with this (allow[]/hooks concatenate).",

  "//model": "Set your default with /model in-session, or uncomment below:",
  "//model_value": "\"model\": \"claude-opus-4-8\",",

  "permissions": {
    "//": "default | acceptEdits | plan | bypassPermissions. acceptEdits auto-applies file edits but still asks before running commands. Unlisted Bash commands fall through to this mode (i.e. ask).",
    "defaultMode": "acceptEdits",

    "//rules": "Precedence is deny > ask > allow. Granular git: most subcommands allowed, but reset --hard / push --force denied. Pruned to tools actually installed (Brewfile + mise); removed gem/rbenv/bundle/ruby, jj, glab, tmux, nvim, atuin, asciinema, agg, gifski, nmap, cloudflared, pscale, yarn, wrk, try, omz, age, shellcheck, pipx, wget, htop. Kept/added mise, eza, btop, xh which the template missed.",

    "allow": [
      "Read",
      "Edit",

      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git show:*)",
      "Bash(git stash list:*)",
      "Bash(git remote:*)",
      "Bash(git fetch:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git checkout:*)",
      "Bash(git switch:*)",
      "Bash(git merge:*)",
      "Bash(git clone:*)",
      "Bash(git pull:*)",
      "Bash(git init:*)",
      "Bash(git worktree:*)",
      "Bash(git rebase:*)",
      "Bash(git push:*)",
      "Bash(git reset --soft:*)",

      "Bash(ls:*)",
      "Bash(eza:*)",
      "Bash(cat:*)",
      "Bash(bat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(find:*)",
      "Bash(fd:*)",
      "Bash(rg:*)",
      "Bash(grep:*)",
      "Bash(tree:*)",

      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(wc:*)",
      "Bash(cut:*)",
      "Bash(awk:*)",
      "Bash(sed:*)",
      "Bash(tr:*)",
      "Bash(xargs:*)",
      "Bash(tee:*)",
      "Bash(diff:*)",
      "Bash(comm:*)",
      "Bash(paste:*)",
      "Bash(column:*)",
      "Bash(jq:*)",

      "Bash(which:*)",
      "Bash(type:*)",
      "Bash(file:*)",
      "Bash(stat:*)",
      "Bash(du:*)",
      "Bash(df:*)",
      "Bash(env)",
      "Bash(printenv:*)",
      "Bash(uname:*)",
      "Bash(hostname)",
      "Bash(whoami)",
      "Bash(id)",
      "Bash(date:*)",
      "Bash(pwd)",
      "Bash(echo:*)",
      "Bash(printf:*)",

      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",

      "Bash(mise:*)",
      "Bash(pnpm:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(node:*)",
      "Bash(bun:*)",
      "Bash(wrangler:*)",

      "Bash(go:*)",
      "Bash(rustc:*)",
      "Bash(cargo:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(pip:*)",
      "Bash(pip3:*)",
      "Bash(uv:*)",
      "Bash(ruff:*)",
      "Bash(make:*)",
      "Bash(cmake:*)",

      "Bash(gh pr list:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh pr status:*)",
      "Bash(gh pr create:*)",
      "Bash(gh issue list:*)",
      "Bash(gh issue view:*)",
      "Bash(gh issue status:*)",
      "Bash(gh issue create:*)",
      "Bash(gh repo view:*)",
      "Bash(gh repo clone:*)",
      "Bash(gh api:*)",
      "Bash(gh search:*)",
      "Bash(gh status:*)",
      "Bash(gh run list:*)",
      "Bash(gh run view:*)",
      "Bash(gh run watch:*)",
      "Bash(gh workflow list:*)",
      "Bash(gh workflow view:*)",
      "Bash(gh cache list:*)",
      "Bash(gh release list:*)",
      "Bash(gh release view:*)",
      "Bash(gh gist list:*)",
      "Bash(gh gist view:*)",
      "Bash(gh label list:*)",
      "Bash(gh ruleset list:*)",
      "Bash(gh ruleset view:*)",

      "Bash(lsof:*)",
      "Bash(curl:*)",
      "Bash(xh:*)",
      "Bash(websocat:*)",
      "Bash(ffmpeg:*)",
      "Bash(mkcert:*)",
      "Bash(stow:*)",
      "Bash(zoxide:*)",
      "Bash(btop:*)",
      "Bash(fzf:*)",
      "Bash(delta:*)",

      "Bash(docker:*)",
      "Bash(docker-compose:*)",

      "Bash(brew:*)",
      "Bash(open:*)",
      "Bash(pbcopy)",
      "Bash(pbpaste)",
      "Bash(source:*)"
    ],

    "ask": [
      "Bash(rm:*)",
      "Bash(kill:*)",
      "Bash(gh pr merge:*)",
      "Bash(gh pr close:*)",
      "Bash(gh issue close:*)",
      "Bash(gh run cancel:*)",
      "Bash(gh run rerun:*)",
      "Bash(gh release create:*)"
    ],

    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./**/.env)",
      "Read(./secrets/**)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Bash(rm -rf:*)",
      "Bash(git reset --hard:*)",
      "Bash(git push --force:*)",
      "Bash(gh release delete:*)"
    ]
  },

  "includeCoAuthoredBy": false,
  "cleanupPeriodDays": 30,
  "env": {}
}
